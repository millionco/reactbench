+        return
+      }
+      setIsPrivateKeyDragOver(false)
+    },
+    []
+  )
+
+  const handlePrivateKeyDropzoneClick = useCallback(() => {
+    privateKeyFileInputRef.current?.click()
+  }, [])
+
+  const markPrivateKeyEdited = useCallback(() => {
+    cancelPendingPrivateKeyRead()
+    setPrivateKeyFileName(null)
+    resetPrivateKeyFileInput()
+  }, [cancelPendingPrivateKeyRead, resetPrivateKeyFileInput])
+
+  const clearPrivateKeyUpload = useCallback(() => {
+    cancelPendingPrivateKeyRead()
+    setPrivateKeyFileName(null)
+    resetPrivateKeyFileInput()
+  }, [cancelPendingPrivateKeyRead, resetPrivateKeyFileInput])
+
+  return {
+    privateKeyFileName,
+    privateKeyLoadingName,
+    isPrivateKeyDragOver,
+    privateKeyFileInputRef,
+    handlePrivateKeyInputChange,
+    handlePrivateKeyDrop,
+    handlePrivateKeyDragOver,
+    handlePrivateKeyDragLeave,
+    handlePrivateKeyDropzoneClick,
+    markPrivateKeyEdited,
+    clearPrivateKeyUpload,
+  }
+}
