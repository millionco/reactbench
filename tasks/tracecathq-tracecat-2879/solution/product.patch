+      setIsPrivateKeyDragOver(true)
+    },
+    []
+  )
+
+  const handlePrivateKeyDragLeave = useCallback(
+    (event: DragEvent<HTMLButtonElement>) => {
+      const relatedTarget = event.relatedTarget
+      if (
