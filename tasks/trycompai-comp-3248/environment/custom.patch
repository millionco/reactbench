diff --git a/apps/framework-editor/app/components/table/column-widths-cookie.ts b/apps/framework-editor/app/components/table/column-widths-cookie.ts
new file mode 100644
index 000000000..35e0f22e9
--- /dev/null
+++ b/apps/framework-editor/app/components/table/column-widths-cookie.ts
@@ -0,0 +1,50 @@
+import { useState } from 'react';
+
+const COOKIE_MAX_AGE_SECONDS = 31_536_000;
+
+export const sanitizeColumnWidths = (value: unknown): Record<string, number> => {
+  if (typeof value !== 'object' || value === null || Array.isArray(value)) {
+    return {};
+  }
+
+  return Object.fromEntries(
+    Object.entries(value).flatMap(([columnKey, width]) =>
+      typeof width === 'number' && Number.isFinite(width) && width >= 1
+        ? [[columnKey, Math.round(width)]]
+        : [],
+    ),
+  );
+};
+
+export const loadColumnWidths = (cookieName: string): Record<string, number> => {
+  if (typeof document === 'undefined') {
+    return {};
+  }
+
+  try {
+    const prefix = `${cookieName}=`;
+    const cookie = document.cookie.split('; ').find((entry) => entry.startsWith(prefix));
+    return cookie
+      ? sanitizeColumnWidths(JSON.parse(decodeURIComponent(cookie.slice(prefix.length))))
+      : {};
+  } catch {
+    return {};
+  }
+};
+
+export const saveColumnWidths = (
+  cookieName: string,
+  widths: Record<string, number>,
+): void => {
+  if (typeof document === 'undefined') {
+    return;
+  }
+
+  const value = encodeURIComponent(JSON.stringify(sanitizeColumnWidths(widths)));
+  document.cookie = `${cookieName}=${value}; path=/; max-age=${COOKIE_MAX_AGE_SECONDS}; samesite=lax`;
+};
+
+export const useSavedColumnWidths = (cookieName: string): Record<string, number> => {
+  const [savedWidths] = useState(() => loadColumnWidths(cookieName));
+  return savedWidths;
+};
