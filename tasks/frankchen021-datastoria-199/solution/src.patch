diff --git a/src/components/chat/message/message-markdown-math.ts b/src/components/chat/message/message-markdown-math.ts
index 49d1269..d0bf865 100644
--- a/src/components/chat/message/message-markdown-math.ts
+++ b/src/components/chat/message/message-markdown-math.ts
@@ -1,4 +1,262 @@
-export const normalizeMathMarkdown = (text: string) =>
-  text
-    .replace(/\\\(([\s\S]*?)\\\)/g, "$$$1$")
-    .replace(/\\\[([\s\S]*?)\\\]/g, "\n\n$$$$\n$1\n$$$$\n\n");
+import { MINIMUM_CODE_FENCE_LENGTH } from "./message-markdown-constants";
+
+interface CodeFence {
+  character: "`" | "~";
+  length: number;
+}
+
+interface DisplayMathBlock {
+  contentLines: string[];
+  endIndex: number;
+  indentation: string;
+}
+
+const countRepeatedCharacter = (
+  source: string,
+  startIndex: number,
+  character: string,
+) => {
+  let endIndex = startIndex;
+  while (source[endIndex] === character) {
+    endIndex += 1;
+  }
+  return endIndex - startIndex;
+};
+
+const getLineEnd = (source: string, startIndex: number) => {
+  const newlineIndex = source.indexOf("\n", startIndex);
+  return newlineIndex === -1 ? source.length : newlineIndex;
+};
+
+const getOpeningFence = (line: string): CodeFence | null => {
+  const indentationLength = line.match(/^[ \t]*/)?.[0].length ?? 0;
+  if (indentationLength > MINIMUM_CODE_FENCE_LENGTH) {
+    return null;
+  }
+
+  const character = line[indentationLength];
+  if (character !== "`" && character !== "~") {
+    return null;
+  }
+
+  const length = countRepeatedCharacter(line, indentationLength, character);
+  if (length < MINIMUM_CODE_FENCE_LENGTH) {
+    return null;
+  }
+
+  return { character, length };
+};
+
+const isClosingFence = (line: string, fence: CodeFence) => {
+  const indentationLength = line.match(/^[ \t]*/)?.[0].length ?? 0;
+  if (indentationLength > MINIMUM_CODE_FENCE_LENGTH) {
+    return false;
+  }
+
+  const markerLength = countRepeatedCharacter(
+    line,
+    indentationLength,
+    fence.character,
+  );
+  return (
+    markerLength >= fence.length &&
+    line.slice(indentationLength + markerLength).trim() === ""
+  );
+};
+
+const findFenceEnd = (source: string, startIndex: number) => {
+  const openingLineEnd = getLineEnd(source, startIndex);
+  const openingFence = getOpeningFence(source.slice(startIndex, openingLineEnd));
+  if (!openingFence) {
+    return null;
+  }
+
+  let lineStartIndex =
+    openingLineEnd < source.length ? openingLineEnd + 1 : source.length;
+  while (lineStartIndex < source.length) {
+    const lineEndIndex = getLineEnd(source, lineStartIndex);
+    if (
+      isClosingFence(
+        source.slice(lineStartIndex, lineEndIndex),
+        openingFence,
+      )
+    ) {
+      return lineEndIndex < source.length ? lineEndIndex + 1 : lineEndIndex;
+    }
+    lineStartIndex =
+      lineEndIndex < source.length ? lineEndIndex + 1 : source.length;
+  }
+
+  return source.length;
+};
+
+const findInlineCodeEnd = (
+  source: string,
+  startIndex: number,
+  delimiterLength: number,
+) => {
+  let candidateIndex = source.indexOf("`", startIndex);
+  while (candidateIndex !== -1) {
+    const candidateLength = countRepeatedCharacter(
+      source,
+      candidateIndex,
+      "`",
+    );
+    if (candidateLength === delimiterLength) {
+      return candidateIndex + candidateLength;
+    }
+    candidateIndex = source.indexOf("`", candidateIndex + candidateLength);
+  }
+  return null;
+};
+
+const stripIndentation = (line: string, indentation: string) =>
+  line.startsWith(indentation) ? line.slice(indentation.length) : line;
+
+const getDisplayMathBlock = (
+  source: string,
+  startIndex: number,
+): DisplayMathBlock | null => {
+  const openingLineEnd = getLineEnd(source, startIndex);
+  const openingLine = source.slice(startIndex, openingLineEnd);
+  const openingMatch = openingLine.match(/^([ \t]*)\\\[(.*)$/);
+  if (!openingMatch) {
+    return null;
+  }
+
+  const indentation = openingMatch[1] ?? "";
+  const openingRemainder = openingMatch[2] ?? "";
+  const sameLineClosingIndex = openingRemainder.indexOf("\\]");
+  if (sameLineClosingIndex !== -1) {
+    if (openingRemainder.slice(sameLineClosingIndex + 2).trim() !== "") {
+      return null;
+    }
+    return {
+      contentLines: [
+        openingRemainder.slice(0, sameLineClosingIndex).trim(),
+      ],
+      endIndex:
+        openingLineEnd < source.length ? openingLineEnd + 1 : openingLineEnd,
+      indentation,
+    };
+  }
+  if (openingRemainder.trim() !== "") {
+    return null;
+  }
+
+  const contentLines: string[] = [];
+  let lineStartIndex =
+    openingLineEnd < source.length ? openingLineEnd + 1 : source.length;
+  while (lineStartIndex < source.length) {
+    const lineEndIndex = getLineEnd(source, lineStartIndex);
+    const line = source.slice(lineStartIndex, lineEndIndex);
+    if (/^[ \t]*\\\][ \t]*$/.test(line)) {
+      return {
+        contentLines,
+        endIndex: lineEndIndex < source.length ? lineEndIndex + 1 : lineEndIndex,
+        indentation,
+      };
+    }
+    contentLines.push(stripIndentation(line, indentation));
+    lineStartIndex =
+      lineEndIndex < source.length ? lineEndIndex + 1 : source.length;
+  }
+
+  return null;
+};
+
+const trimBlankContentLines = (contentLines: string[]) => {
+  let startIndex = 0;
+  let endIndex = contentLines.length;
+  while (startIndex < endIndex && contentLines[startIndex]?.trim() === "") {
+    startIndex += 1;
+  }
+  while (endIndex > startIndex && contentLines[endIndex - 1]?.trim() === "") {
+    endIndex -= 1;
+  }
+  return contentLines.slice(startIndex, endIndex);
+};
+
+const ensureTrailingBlankLine = (source: string) => {
+  if (source.length === 0 || source.endsWith("\n\n")) {
+    return source;
+  }
+  return source.endsWith("\n") ? `${source}\n` : `${source}\n\n`;
+};
+
+const formatDisplayMath = (block: DisplayMathBlock) => {
+  const content = trimBlankContentLines(block.contentLines)
+    .map((line) => `${block.indentation}${line.trimEnd()}`)
+    .join("\n");
+  return `${block.indentation}$$\n${content}\n${block.indentation}$$`;
+};
+
+export const normalizeMathMarkdown = (text: string) => {
+  let normalizedText = "";
+  let currentIndex = 0;
+  let isLineStart = true;
+
+  while (currentIndex < text.length) {
+    if (isLineStart) {
+      const fenceEndIndex = findFenceEnd(text, currentIndex);
+      if (fenceEndIndex !== null) {
+        normalizedText += text.slice(currentIndex, fenceEndIndex);
+        currentIndex = fenceEndIndex;
+        isLineStart = true;
+        continue;
+      }
+
+      const displayMathBlock = getDisplayMathBlock(text, currentIndex);
+      if (displayMathBlock) {
+        normalizedText = ensureTrailingBlankLine(normalizedText);
+        normalizedText += formatDisplayMath(displayMathBlock);
+        currentIndex = displayMathBlock.endIndex;
+        if (currentIndex < text.length) {
+          normalizedText += "\n\n";
+        }
+        isLineStart = true;
+        continue;
+      }
+    }
+
+    if (text[currentIndex] === "`") {
+      const delimiterLength = countRepeatedCharacter(
+        text,
+        currentIndex,
+        "`",
+      );
+      const inlineCodeEndIndex = findInlineCodeEnd(
+        text,
+        currentIndex + delimiterLength,
+        delimiterLength,
+      );
+      if (inlineCodeEndIndex !== null) {
+        const inlineCode = text.slice(currentIndex, inlineCodeEndIndex);
+        normalizedText += inlineCode;
+        isLineStart = inlineCode.endsWith("\n");
+        currentIndex = inlineCodeEndIndex;
+        continue;
+      }
+    }
+
+    if (text.startsWith("\\(", currentIndex)) {
+      const closingIndex = text.indexOf("\\)", currentIndex + 2);
+      if (closingIndex !== -1) {
+        const content = text.slice(currentIndex + 2, closingIndex);
