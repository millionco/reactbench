+      throw error;
+    }
+
+    if (!result) return;
+    return Promise.resolve(result).then(
+      () => {
+        if (activeLocalizationControllerRef.current === controller) {
+          activeLocalizationControllerRef.current = null;
+        }
+      },
+      (error: unknown) => {
+        if (activeLocalizationControllerRef.current === controller) {
+          activeLocalizationControllerRef.current = null;
