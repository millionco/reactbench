@@ -27,0 +35,82 @@ const KIND_COLOR: Record<string, string> = {
+interface LocalizationEmptyStateProps {
+  onLocalize?: (() => void | Promise<void>) | undefined;
+  status?: "running" | "failed" | undefined;
+}
+
+interface LocalizationAttemptState {
+  callbackGeneration: number;
+  phase: "pending" | "failed";
+}
+
+function LocalizationEmptyState({ onLocalize, status }: LocalizationEmptyStateProps) {
+  const callbackBoundaryRef = useRef({ callback: onLocalize, generation: 0 });
+  if (callbackBoundaryRef.current.callback !== onLocalize) {
+    callbackBoundaryRef.current = {
+      callback: onLocalize,
+      generation: callbackBoundaryRef.current.generation + 1,
+    };
+  }
+  const callbackGeneration = callbackBoundaryRef.current.generation;
+  const activeGenerationRef = useRef<number | null>(null);
+  const [attemptState, setAttemptState] = useState<LocalizationAttemptState | null>(null);
+  const currentAttempt = attemptState?.callbackGeneration === callbackGeneration
+    ? attemptState
+    : null;
+
+  const handleLocalize = () => {
+    if (!onLocalize || activeGenerationRef.current === callbackGeneration) return;
+    activeGenerationRef.current = callbackGeneration;
+    setAttemptState({ callbackGeneration, phase: "pending" });
+
+    let result: void | Promise<void>;
+    try {
+      result = onLocalize();
+    } catch {
+      if (activeGenerationRef.current === callbackGeneration) {
+        activeGenerationRef.current = null;
+        setAttemptState({ callbackGeneration, phase: "failed" });
+      }
+      return;
+    }
+
+    if (result) {
+      void result.then(
+        () => {
+          if (activeGenerationRef.current !== callbackGeneration) return;
+          activeGenerationRef.current = null;
+          setAttemptState(null);
+        },
+        () => {
+          if (activeGenerationRef.current !== callbackGeneration) return;
+          activeGenerationRef.current = null;
+          setAttemptState({ callbackGeneration, phase: "failed" });
+        },
+      );
+    }
+  };
+
+  if (status === "running") {
+    return <span data-testid="geo-localizing">localizing…</span>;
+  }
+  if (status === "failed" && !onLocalize) {
+    return <span>nothing localized for this page</span>;
+  }
+  if (!onLocalize) {
+    return <span>no localized geometry for this page</span>;
+  }
+
+  return (
+    <button
+      type="button"
+      data-testid="geo-localize"
+      onClick={handleLocalize}
+      disabled={currentAttempt?.phase === "pending"}
+      className="underline decoration-dotted underline-offset-2 hover:text-emerald-300"
+    >
+      {status === "failed" || currentAttempt?.phase === "failed"
+        ? "nothing localized — retry"
+        : "no localized geometry — localize now"}
+    </button>
+  );
+}
+
